# .gitignore

# 1. 忽略编译生成目录
build/
bin/
out/

# 2. 忽略编译中间文件
*.o
*.a
*.so
*.exe
*.obj
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# 3. 忽略 IDE 配置
.vscode/
.idea/
*.user
*.suo

# 4. 忽略特定可执行文件 (已删除 GateServer 防止误伤源码目录)

# 5. 忽略系统文件
.DS_Store

# 6. gRPC & Protobuf 生成文件 (如果你不想提交自动生成的代码，保留这些；如果想提交，就把下面几行删掉)
*.pb.cc
*.pb.h
*.grpc.pb.cc
*.grpc.pb.h
